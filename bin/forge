#!/usr/bin/env bash

# FORGE global NPM executable wrapper
echo "⚡ FORGE Autonomous Agent"

FORGE_DIR="$HOME/.forge"
ENGINE="$FORGE_DIR/engine"

if [ "$1" == "install" ]; then
    echo "Installing FORGE engine to ~/.forge..."
    mkdir -p "$FORGE_DIR"
    cp -r "$(dirname "$0")/../forge-engine (1)/forge-publish/forge-engine" "$ENGINE"
    echo "Installation complete. Run 'forge start' to begin."
    exit 0
fi

if [ ! -d "$ENGINE" ]; then
    echo "FORGE engine not found. Please run 'forge install' first."
    exit 1
fi

case "$1" in
    start)
        echo "Booting FORGE core loop..."
        python3 "$ENGINE/core/loop.py"
        ;;
    status)
        echo "Checking FORGE status..."
        # status script logic
        ;;
    *)
        echo "Usage: forge [install|start|status]"
        ;;
esac
